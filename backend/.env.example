# Backend Environment Variables (.env)
# Copy this file to backend/.env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/yoloracer
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Authentication
JWT_SECRET=your-very-secure-jwt-secret-key-change-this
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# CORS & Security
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@yoloracer.pet

# MQTT Configuration (Device Messaging)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password

# Storage (S3/Blob)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=yoloracer-backups

# Monitoring & Logging
SENTRY_DSN=
LOG_DESTINATION=console,file

# Feature Flags
ENABLE_WEBSOCKETS=true
ENABLE_MQTT=true
ENABLE_EMAIL_ALERTS=false

# API Keys
GOOGLE_MAPS_API_KEY=
MAPBOX_API_KEY=
NOMINATIM_API_KEY=

# Development / Testing
DEBUG=yoloracer:*
SEED_TEST_DATA=false
